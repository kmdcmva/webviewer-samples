{
  "name": "webviewer-typescript-sample",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@pdftron/webviewer": "^11.12.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@parcel/config-default": "^2.16.3",
    "fs-extra": "^11.3.2",
    "parcel": "2.16.3",
    "parcel-reporter-multiple-static-file-copier": "^1.0.5"
  },
  "scripts": {
    "start": "parcel public/index.html",
    "copy-webviewer": "node scripts/copy-webviewer-files.cjs"
  },
  "multipleStaticFileCopier": [
    {
      "origin": "node_modules/@pdftron/webviewer/public",
      "destination": "dist/lib"
    }
  ],
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
